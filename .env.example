# AI Support Ticket System - Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (required for AI classification)
GEMINI_API_KEY=your-gemini-api-key-here

# PostgreSQL (defaults are fine for Docker)
POSTGRES_DB=tickets_db
POSTGRES_USER=tickets_user
POSTGRES_PASSWORD=tickets_pass

# Django
DJANGO_SECRET_KEY=change-this-in-production
DEBUG=True
